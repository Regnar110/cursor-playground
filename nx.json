{
  "$schema": "./node_modules/nx/schemas/nx-schema.json",
  "defaultBase": "main",
  "namedInputs": {
    "default": ["{projectRoot}/**/*"]
  },
  "targetDefaults": {
    "build": {
      "cache": true,
      "inputs": ["default"],
      "outputs": ["{projectRoot}/.next"]
    },
    "lint": {
      "cache": true
    }
  }
}
