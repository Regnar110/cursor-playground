# Redis connection (remote cache handler — use cache: remote)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_DB=0
# REDIS_PASSWORD=

# Single-flight lock
SINGLE_FLIGHT_LOCK_TTL=30
SINGLE_FLIGHT_POLLING_MS=100
SINGLE_FLIGHT_ATTEMPTS=50

# Invalidation metadata (meta:revalidated-at:*)
TAG_META_TTL_SECONDS=604800

# L1 LRU (in-process)
REMOTE_CACHE_LRU_MAX_ENTRIES=500
REMOTE_CACHE_LRU_MAX_SIZE_MB=50
REMOTE_CACHE_LRU_DEFAULT_ENTRY_SIZE_BYTES=1024
REMOTE_CACHE_LRU_TTL_MS=15000

# Debug mode (off by default). Set to a secret token to enable:
# - readable multi-line logs in stderr (docker compose logs)
# - GET /cache-debug?token=<secret>  — HTML dashboard (this instance only)
# - GET /api/cache-debug?token=<secret>  — JSON or Accept: text/plain
# REMOTE_CACHE_DEBUG=change-me-local-only
# REMOTE_CACHE_DEBUG_MAX_EVENTS=200
